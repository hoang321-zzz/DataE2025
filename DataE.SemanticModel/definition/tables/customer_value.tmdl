table customer_value
	lineageTag: ef34c87d-9758-47ad-94b5-a17037f673de

	measure 'Pareto khách hàng' = ```
			
			VAR doanhthu = SUM(customer_value[Monetary])
			VAR luyke = 
			    SUMX(
			        FILTER(
			            SUMMARIZE(ALLSELECTED(customer_value),customer_value[Segment],"Amount",SUM(customer_value[Monetary])),
			            [Amount] >= doanhthu), [Amount])
			var tongdoanhthu = CALCULATE(SUM(customer_value[Monetary]), ALLSELECTED(customer_value))
			RETURN luyke/tongdoanhthu
			```
		lineageTag: 1750fda9-19ca-4b18-a19c-b91e86d6c5a0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

