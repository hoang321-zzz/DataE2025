	partition KPI = m
		mode: import
		source =
				let
				    Source = Sql.Database("DESKTOP-R39PBBV\SQLEXPRESS", "DataE2025", [Query="--CTE to compare revenue and KPI    #(lf)WITH DoanhThuKPI AS (#(lf)    SELECT #(lf)        FORMAT([Ngày_hạch_toán], 'yyyy-MM') AS YearMonth,        -- Create YearMonth in dulieubanhang#(lf)        [Chi_nhánh],#(lf)        SUM([Doanh_thu]) AS TongDoanhThu#(lf)    FROM [dbo].[dulieubanhang]#(lf)    GROUP BY #(lf)        FORMAT([Ngày_hạch_toán], 'yyyy-MM'), #(lf)        [Chi_nhánh]#(lf))#(lf)SELECT #(lf)    dt.YearMonth AS Thang,#(lf)    cn.[Tên_chi_nhánh],#(lf)    dt.TongDoanhThu AS DoanhThuThucTe,#(lf)    kpi.KPI AS MucTieuKPI,#(lf)    (dt.TongDoanhThu - kpi.KPI) AS ChenhLech,#(lf)    ROUND((dt.TongDoanhThu / kpi.KPI) * 100, 2) AS percent_of_kpi     -- % of kpi#(lf)FROM DoanhThuKPI dt#(lf)JOIN [dbo].[chinhanh] cn #(lf)    ON dt.[Chi_nhánh] = cn.Mã_chi_nhánh#(lf)JOIN [KPI] kpi #(lf)    ON dt.YearMonth = kpi.[YearMonth] AND dt.Chi_nhánh = kpi.Mã_chi_nhánh#(lf)ORDER BY #(lf)    dt.YearMonth ASC, #(lf)    percent_of_kpi DESC; "]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Thang", type date}}),
				    #"Added Custom Column" = Table.AddColumn(#"Changed Type", "Tháng-Năm", each Text.Combine({Date.ToText([Thang], "yyyy"), Date.ToText([Thang], "MM")}), type text),
				    #"Changed Type1" = Table.TransformColumnTypes(#"Added Custom Column",{{"Thang", type datetime}})
				in
				    #"Changed Type1"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

