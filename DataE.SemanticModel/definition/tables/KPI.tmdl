table KPI
	lineageTag: 059620ab-08c9-4457-a0e6-1a0db8a11a50

	measure DoanhThuCaNam = SUM('KPI'[DoanhThuThucTe])
		lineageTag: 045a9fb6-42ea-43e6-858d-ebd448013167

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Goal_KPI_Moi = ```
			
			// 1. Dùng ALLSELECTED để lấy đúng khoảng thời gian từ Slicer, bỏ qua trục Trend của biểu đồ
			VAR MinSlicerDate = CALCULATE(MIN('Calendar'[Date]), ALLSELECTED('Calendar'[Date]))
			VAR MaxSlicerDate = CALCULATE(MAX('Calendar'[Date]), ALLSELECTED('Calendar'[Date]))
			
			// 2. Kiểm tra nếu không có ngày nào được chọn thì trả về trống để tránh lỗi hàm DATE
			VAR Result = 
			IF(
			    ISBLANK(MinSlicerDate) || ISBLANK(MaxSlicerDate),
			    BLANK(),
			    
			    // Đưa về mùng 1 của tháng bắt đầu và kết thúc
			    VAR StartTargetMonth = DATE(YEAR(MinSlicerDate), MONTH(MinSlicerDate), 1)
			    VAR EndTargetMonth = DATE(YEAR(MaxSlicerDate), MONTH(MaxSlicerDate), 1)
			    
			    RETURN
			    CALCULATE(
			        SUM('KPI'[MucTieuKPI]),
			        REMOVEFILTERS('Calendar'), 
			        'KPI'[Thang] >= StartTargetMonth,
			        'KPI'[Thang] <= EndTargetMonth
			    )
			)
			
			RETURN Result
			```
		lineageTag: 9c6a4a38-1e47-491e-bcb1-0cc9776ba523

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure DoanhThuTheoSlicer_Moi = ```
			
			// 1. Dùng ALLSELECTED để lấy đúng khoảng thời gian từ Slicer, bỏ qua trục Trend của biểu đồ
			VAR MinSlicerDate = CALCULATE(MIN('Calendar'[Date]), ALLSELECTED('Calendar'[Date]))
			VAR MaxSlicerDate = CALCULATE(MAX('Calendar'[Date]), ALLSELECTED('Calendar'[Date]))
			
			// 2. Kiểm tra nếu không có ngày nào được chọn thì trả về trống để tránh lỗi hàm DATE
			VAR Result = 
			IF(
			    ISBLANK(MinSlicerDate) || ISBLANK(MaxSlicerDate),
			    BLANK(),
			    
			    // Đưa về mùng 1 của tháng bắt đầu và kết thúc
			    VAR StartTargetMonth = DATE(YEAR(MinSlicerDate), MONTH(MinSlicerDate), 1)
			    VAR EndTargetMonth = DATE(YEAR(MaxSlicerDate), MONTH(MaxSlicerDate), 1)
			    
			    RETURN
			    CALCULATE(
			        SUM('KPI'[DoanhThuThucTe]),
			        REMOVEFILTERS('Calendar'), 
			        'KPI'[Thang] >= StartTargetMonth,
			        'KPI'[Thang] <= EndTargetMonth
			    )
			)
			
			RETURN Result*(1-('Discount (%)'[Discount (%) Value]/100))
			```
		lineageTag: 688d4c9d-476f-4a4a-b8f6-bf413bda5dc9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

