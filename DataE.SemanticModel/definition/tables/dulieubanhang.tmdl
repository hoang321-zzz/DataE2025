	partition dulieubanhang = m
		mode: import
		source =
				let
				    Source = Sql.Database("DESKTOP-R39PBBV\SQLEXPRESS", "DataE2025", [Query="--CTE to identify if there are duplicate records#(lf)WITH DuplicateRecords AS (#(lf)#(tab)SELECT#(lf)#(tab)#(tab)[Ngày_hạch_toán],#(lf)#(tab)#(tab)[Đơn_hàng],#(lf)#(tab)#(tab)[Mã_KH],#(lf)#(tab)#(tab)[Mã_Sản_Phẩm],#(lf)#(tab)#(tab)[Số_lượng_bán],#(lf)#(tab)#(tab)[Đơn_giá],#(lf)#(tab)#(tab)[Doanh_thu],#(lf)#(tab)#(tab)[Giá_vốn_hàng_hóa],#(lf)#(tab)#(tab)[Mã_nhân_viên_bán],#(lf)#(tab)#(tab)[Chi_nhánh],#(lf)#(tab)#(tab)ROW_NUMBER() OVER(#(lf)#(tab)#(tab)#(tab)PARTITION BY [Ngày_hạch_toán],[Mã_KH],[Mã_Sản_Phẩm],[Số_lượng_bán],[Đơn_giá],[Doanh_thu],[Giá_vốn_hàng_hóa],[Mã_nhân_viên_bán],[Chi_nhánh]#(tab)#(tab)#(tab)ORDER BY [Đơn_hàng]#(lf)#(tab)#(tab)#(tab)) AS row_num#(lf)#(tab)FROM dbo.dulieubanhang#(lf))#(lf)#(lf)SELECT [Ngày_hạch_toán],#(lf)#(tab)#(tab)[Đơn_hàng],#(lf)#(tab)#(tab)[Mã_KH],#(lf)#(tab)#(tab)[Mã_Sản_Phẩm],#(lf)#(tab)#(tab)[Số_lượng_bán],#(lf)#(tab)#(tab)[Đơn_giá],#(lf)#(tab)#(tab)[Doanh_thu],#(lf)#(tab)#(tab)[Giá_vốn_hàng_hóa],#(lf)#(tab)#(tab)[Mã_nhân_viên_bán],#(lf)#(tab)#(tab)[Chi_nhánh]#(lf)FROM DuplicateRecords#(lf)WHERE row_num = 1#(lf)ORDER BY Đơn_hàng#(lf)"])
				in
				    Source

