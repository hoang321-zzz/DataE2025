	partition Calendar = calculated
		mode: import
		source = ```
				
				-- 1. Tự động lấy khoảng ngày dựa trên dữ liệu bán hàng của bạn
				VAR MinDate = MIN('dulieubanhang'[Ngày_hạch_toán])
				VAR MaxDate = MAX('dulieubanhang'[Ngày_hạch_toán])
				
				RETURN
				ADDCOLUMNS (
				    -- Tạo một danh sách các ngày liên tục từ MinDate đến MaxDate
				    CALENDAR ( MinDate, MaxDate ),
				    
				    -- Thêm các cột phân tích thời gian thông dụng
				    "Year", YEAR ( [Date] ),
				    "Quarter", "Q" & FORMAT ( [Date], "Q" ),
				    "Month Number", MONTH ( [Date] ),
				    "Month Name (EN)", FORMAT ( [Date], "mmmm" ),                    -- January, February...
				    "Month Name (VI)", "Tháng " & MONTH ( [Date] ),                  -- Tháng 1, Tháng 2...
				    "Month Short", FORMAT ( [Date], "mmm" ),                        -- Jan, Feb...
				    "Week Number", WEEKNUM ( [Date], 2 ),                            -- Tuần trong năm (bắt đầu từ Thứ 2)
				    "Day", DAY ( [Date] ),
				    "Day of Week", WEEKDAY ( [Date], 2 ),                            -- Số thứ tự ngày trong tuần (1 = Thứ 2, 7 = Chủ Nhật)
				    "Day Name (EN)", FORMAT ( [Date], "dddd" ),                      -- Monday, Tuesday...
				    "Day Name (VI)", 
				        SWITCH ( 
				            WEEKDAY ( [Date], 2 ),
				            1, "Thứ Hai", 2, "Thứ Ba", 3, "Thứ Tư", 
				            4, "Thứ Năm", 5, "Thứ Sáu", 6, "Thứ Bảy", 7, "Chủ Nhật"
				        ),
				    "Year Month YYYYMM", FORMAT ( [Date], "YYYYMM" ),                -- Số nguyên (Ví dụ: 202401) dùng để Sort dữ liệu
				    "Year Month", FORMAT ( [Date], "YYYY-MM" ),                      -- Dạng chuỗi (Ví dụ: 2024-01) để hiển thị lên biểu đồ
				    "Year Quarter", YEAR ( [Date] ) & "-Q" & FORMAT ( [Date], "Q" )  -- Ví dụ: 2024-Q1
				)
				```

	annotation PBI_Id = 1af5db9e7db54aaea76456f4ceea6af0

